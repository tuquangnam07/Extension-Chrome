{
  "manifest_version": 3,
  "name": "Garena Auto Register Pro",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://sso.garena.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://sso.garena.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
